local function GetTradeValues(tradeGui)
    local vals = {}
    for _, obj in pairs(tradeGui:GetDescendants()) do
        if obj:IsA("TextLabel") and obj.Visible and string.find(obj.Text, "Value: %$") then
            local numStr = string.match(obj.Text, "^Value: %$([%d%,]+)")
            if numStr then
                local val = tonumber((string.gsub(numStr, ",", "")))
                if val then
                    vals[math.floor(obj.AbsolutePosition.X)] = val
                end
            end
        end
    end
    
    local sortedX = {}
    for x in pairs(vals) do table.insert(sortedX, x) end
    table.sort(sortedX)
    
    local myVal = sortedX[1] and vals[sortedX[1]] or 0
    local oppVal = sortedX[2] and vals[sortedX[2]] or 0
    return myVal, oppVal
end

local function IsTradeBalanced(myVal, oppVal)
    if myVal == 0 or oppVal == 0 then return false end
    local maxVal = math.max(myVal, oppVal)
    local diff = math.abs(myVal - oppVal) / maxVal
    return diff <= 0.4
end

local function KiemTraTrangThai(tradeGui)
    for _, v in pairs(tradeGui:GetDescendants()) do
        if v:IsA("TextLabel") and v.Visible then
            local text = string.lower(v.Text)
            if string.find(text, "enough space") then return "FULL_SPACE" end
            if v.Text == "Ready!" then return "READY" end
        end
    end
    return "NONE"
end

local function isTrulyVisible(guiObj)
    local curr = guiObj
    while curr and curr:IsA("GuiObject") do
        if not curr.Visible then return false end
        curr = curr.Parent
    end
    return true
end

-- CHỈ BẤM 1 LẦN DUY NHẤT (Chống Double-Click tháo trái)
local function VIM_Click(guiObj)
    if not guiObj then return end
    local center = guiObj.AbsolutePosition + (guiObj.AbsoluteSize / 2)
    local inset = GuiService:GetGuiInset()
    local x = center.X
    local y = center.Y + inset.Y
    
    pcall(function()
        VIM:SendMouseButtonEvent(x, y, 0, true, game, 1)
        task.wait(0.05)
        VIM:SendMouseButtonEvent(x, y, 0, false, game, 1)
    end)
end

local function ClickDauCong(tradeGui)
    local guiCenter = tradeGui.AbsolutePosition.X + (tradeGui.AbsoluteSize.X / 2)
    for _, obj in pairs(tradeGui:GetDescendants()) do
        if obj:IsA("ImageButton") and obj.AbsoluteSize.X > 50 and obj.AbsoluteSize.Y > 50 and isTrulyVisible(obj) then
            if obj.AbsolutePosition.X < guiCenter then
                local isFilled = false
                for _, child in pairs(obj:GetDescendants()) do
                    if child:IsA("TextLabel") and string.find(child.Text, "%$") then isFilled = true break end
                end
                if not isFilled then
                    VIM_Click(obj)
                    return true
                end
            end
        end
    end
    return false
end

local function ClickTraiTuUI(tradeGui)
    for _, name in ipairs(Config.DanhSachTrai) do
        if TraiDaThu[name] then continue end 
        local shortName = name
        if name == "T-Rex-T-Rex" then shortName = "T-Rex" else shortName = string.match(name, "^(.-)%-") or name end
        
        for _, obj in pairs(tradeGui:GetDescendants()) do
            if obj:IsA("TextLabel") and obj.Text == shortName and isTrulyVisible(obj) then
                local scroll = obj:FindFirstAncestorOfClass("ScrollingFrame")
                if scroll then
                    local btn = obj:FindFirstAncestorOfClass("TextButton") or obj:FindFirstAncestorOfClass("ImageButton")
                    if not btn and obj.Parent then btn = obj.Parent end
                    if btn then
                        local targetY = btn.AbsolutePosition.Y - scroll.AbsolutePosition.Y + scroll.CanvasPosition.Y
                        scroll.CanvasPosition = Vector2.new(0, targetY - (scroll.AbsoluteSize.Y / 2))
                        task.wait(0.2)
                        
                        VIM_Click(btn)
                        TraiDaThu[name] = true
                        return shortName
                    end
                end
            end
        end
    end
    return nil
end

local function ClickButtonByText(tradeGui, targetText)
    for _, obj in pairs(tradeGui:GetDescendants()) do
        if obj:IsA("TextLabel") and obj.Text == targetText and isTrulyVisible(obj) then
            local btn = obj:FindFirstAncestorOfClass("TextButton") or obj:FindFirstAncestorOfClass("ImageButton")
            if not btn and obj.Parent then btn = obj.Parent end
            if btn then
                VIM_Click(btn)
                return true
            end
        end
    end
    return false
end
