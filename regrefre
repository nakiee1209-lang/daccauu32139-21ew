end

local function tpToNPC(npcName)
    local npc = findNPC(npcName)
    if npc and npc:FindFirstChild("HumanoidRootPart") then
        local targetPos = CFrame.new(npc.HumanoidRootPart.Position)
        while true do
            local char = lp.Character or lp.CharacterAdded:Wait()
            local hrp  = char:WaitForChild("HumanoidRootPart")
            local hum  = char:WaitForChild("Humanoid")
            if hum.Health <= 0 then
                char = lp.CharacterAdded:Wait()
                hrp  = char:WaitForChild("HumanoidRootPart")
                hum  = char:WaitForChild("Humanoid")
                task.wait(1)
            end
            
            TP1(targetPos)
            
            local reached = false
            local stuckTime = 0
            local lastPos = hrp.Position
            
            while task.wait(0.1) do
                if not char or hum.Health <= 0 then break end
                if (hrp.Position - npc.HumanoidRootPart.Position).Magnitude <= 10 then
                    reached = true
                    break
                end
                if (hrp.Position - lastPos).Magnitude < 1 then
                    stuckTime = stuckTime + 0.1
                    if stuckTime >= 3 then break end
                else
                    stuckTime = 0
                end
                lastPos = hrp.Position
            end
            
            if reached then return true end
            task.wait(0.5)
        end
    end
    return false
end

local function buyDragonTalonWithRetry()
    local MAX_RETRY = 5
    for attempt = 1, MAX_RETRY do
        updateStatus("Đang tìm Uzoth mua Dragon Talon... (" .. attempt .. "/" .. MAX_RETRY .. ")", "BUY_TALON")
        if tpToNPC("Uzoth") then
            task.wait(1)
            pcall(function()
                rs.Remotes.CommF_:InvokeServer("BuyDragonTalon")
            end)
            task.wait(3)
        end
        if hasDragonTalon() then
            updateStatus("Đã mua thành công Dragon Talon!", "BUY_TALON")
            task.wait(2)
            return true
        end
    end
    updateStatus("Không mua được Dragon Talon sau " .. MAX_RETRY .. " lần!", "BUY_TALON")
    return false
end

