local _pulseActive = false
local _pulseThread = nil

local function updateStatus(extraText, state)
    state = state or "FARM_MASTERY"
    pcall(function()
        local color = stateColors[state] or Color3.fromRGB(139, 92, 246)
        local label = stateLabels[state] or tostring(state)
        local img   = stateImages[state] or ""

        StateLabel.Text = label
        ExtraLabel.Text = extraText and extraText:gsub("^%s+", "") or ""
        ItemImage.Image = img
        
        -- Cố gắng thay đổi màu sắc của viền/ảnh theo loại đai
        ItemImage.ImageColor3 = color
        ImgStroke.Color = color

        BorderStroke.Color         = color
        BorderStroke.Transparency  = 0.3
        AccentBar.BackgroundColor3 = color

        _pulseActive = false
        if _pulseThread then
            pcall(function() task.cancel(_pulseThread) end)
            _pulseThread = nil
        end

        AccentBar.BackgroundTransparency = 0
        _pulseActive = true
        _pulseThread = task.spawn(function()
            while _pulseActive do
                local tweenA, tweenB
                local ok = pcall(function()
                    tweenA = TweenService:Create(AccentBar,
                        TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                        { BackgroundTransparency = 0.55 })
                    tweenA:Play()
                    task.wait(1.2)

                    if not _pulseActive then
                        pcall(function() tweenA:Cancel() end)
                        return
                    end

                    tweenB = TweenService:Create(AccentBar,
                        TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                        { BackgroundTransparency = 0 })
                    tweenB:Play()
                    task.wait(1.2)
                end)

                if not _pulseActive then
                    pcall(function() if tweenA then tweenA:Cancel() end end)
                    pcall(function() if tweenB then tweenB:Cancel() end end)
                    break
                end
                if not ok then break end
            end
        end)
    end)
    print("[DRACO] " .. tostring(state) .. (extraText and (" | " .. extraText:gsub("\n", " ")) or ""))
end

