local isHopping = false
local function HopServer()
    if isHopping then return end
    isHopping = true
    
    local HttpService = game:GetService("HttpService")
    local TeleportService = game:GetService("TeleportService")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local player = game.Players.LocalPlayer
    local PlaceId = game.PlaceId
    local JobId = game.JobId

    task.spawn(function()
        pcall(function()
            updateStatus("Đang tìm server mới để nhảy...", "DOJO_PURPLE")
            local sortOrder = math.random() > 0.5 and "Asc" or "Desc"
            local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=" .. sortOrder .. "&limit=100"
            
            local success, result = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
            
            if success and result and result.data then
                local availableServers = {}
                for _, server in pairs(result.data) do
                    if type(server) == "table" and server.id and server.id ~= JobId and server.playing and server.playing < (server.maxPlayers - 2) then
                        table.insert(availableServers, server.id)
                    end
                end
                
                if #availableServers > 0 then
                    task.wait(math.random(1, 3))
                    local randomJobId = availableServers[math.random(1, #availableServers)]
                    updateStatus("✅ Tìm thấy Server, đang dịch chuyển...", "DOJO_PURPLE")
                    
                    pcall(function() ReplicatedStorage:WaitForChild("__ServerBrowser"):InvokeServer("teleport", randomJobId) end)
                    task.wait(2)
                    pcall(function() TeleportService:TeleportToPlaceInstance(PlaceId, randomJobId, player) end)
                else
                    isHopping = false
                    task.wait(math.random(3, 5))
                    HopServer()
                end
            else
                isHopping = false
                task.wait(math.random(5, 10))
                HopServer()
            end
        end)
    end)
end

