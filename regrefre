                return v    
            end
        end
        return false
    end

    local activeBoatTweenConn = nil
    local function TweenBoatTo(boat, targetPos)
        if activeBoatTweenConn then return end
        
        -- Noclip & chống rớt
        for _, part in pairs(boat:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
        local root = boat.PrimaryPart or boat:FindFirstChild("VehicleSeat")
        if root then
            local bv = root:FindFirstChild("SeaBoatBV")
            if not bv then
                bv = Instance.new("BodyVelocity")
                bv.Name = "SeaBoatBV"
                bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                bv.Velocity = Vector3.new(0, 0, 0)
                bv.Parent = root
            end
        end
        
        local startCF = boat:GetPivot()
        -- Nâng y lên xíu để thuyền lướt trên không trung cho ngầu và ko bị cản
        local targetCF = CFrame.lookAt(startCF.Position, targetPos) - startCF.Position + targetPos
        local dist = (startCF.Position - targetPos).Magnitude
        local duration = math.max(0.1, dist / 350)
        local startTime = tick()
        
        activeBoatTweenConn = game:GetService("RunService").Heartbeat:Connect(function()
            if not boat or not boat.Parent or lp.Character.Humanoid.Sit == false then
                activeBoatTweenConn:Disconnect()
                activeBoatTweenConn = nil
                return
            end
            local alpha = math.clamp((tick() - startTime) / duration, 0, 1)
            boat:PivotTo(startCF:Lerp(targetCF, alpha))
            if alpha >= 1 then
                activeBoatTweenConn:Disconnect()
                activeBoatTweenConn = nil
            end
        end)
    end

