local function TP1(pos)
    if not pos then return end
    local e = lp.Character
    if not e or not e:FindFirstChild("HumanoidRootPart") then return end
    local HRP = e.HumanoidRootPart
    local target = typeof(pos) == "CFrame" and pos or CFrame.new(pos)

    _G.shouldTween = true

    if HRP.Anchored then
        HRP.Anchored = false
        task.wait()
    end

    local dist = (target.Position - HRP.Position).Magnitude
    if dist < 5 then return end
    local speed = dist <= 90 and 900 or 350
    local info = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
    
    if (getCDKBlock().Position - HRP.Position).Magnitude > 200 then
        getCDKBlock().CFrame = HRP.CFrame
    end
    if CurTween then pcall(function() CurTween:Cancel(); CurTween = nil end) end
    CurTween = TweenService:Create(getCDKBlock(), info, { CFrame = target })

    if e:FindFirstChildOfClass("Humanoid") and e.Humanoid.Sit == true then
        getCDKBlock().CFrame = CFrame.new(getCDKBlock().Position.X, target.Y, getCDKBlock().Position.Z)
    end

    CurTween:Play()
    task.spawn(function()
        while CurTween and CurTween.PlaybackState == Enum.PlaybackState.Playing do
            if not _G.shouldTween then
                pcall(function() CurTween:Cancel() end)
                break
            end
            task.wait(.1)
        end
    end)
    return true
end

